---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const recipes = await getCollection('recipes');
  return recipes.map(r => ({
    params: { slug: r.slug },
    props: { recipe: r },
  }));
}

const { recipe } = Astro.props;
const { Content } = await recipe.render();
const { title, date, category, tags, image, servings, prepTime, cookTime, description } = recipe.data;

const rawBase = import.meta.env.BASE_URL;
const base = rawBase.endsWith('/') ? rawBase : rawBase + '/';

const categoryMeta: Record<string, { emoji: string; label: string }> = {
  smoking:  { emoji: '🔥', label: 'Smoking' },
  baking:   { emoji: '🍞', label: 'Baking' },
  cooking:  { emoji: '🍳', label: 'Cooking' },
  rubs:     { emoji: '🧂', label: 'Rubs' },
  sauces:   { emoji: '🫙', label: 'Sauces' },
};

const { emoji, label } = categoryMeta[category] ?? { emoji: '🍽️', label: category };
---

<BaseLayout title={title} description={description}>

  <!-- Breadcrumb -->
  <nav class="text-sm text-brown-400 mb-6 flex items-center gap-1.5 flex-wrap">
    <a href={base} class="hover:text-terracotta-600 transition-colors">Home</a>
    <span>/</span>
    <a href={`${base}${category}`} class="hover:text-terracotta-600 transition-colors capitalize">{label}</a>
    <span>/</span>
    <span class="text-brown-700">{title}</span>
  </nav>

  <article class="max-w-3xl mx-auto">

    <!-- Hero image -->
    {image && (
      <div class="rounded-2xl overflow-hidden mb-8 aspect-video shadow-md">
        <img src={`${base}${image}`} alt={title} class="w-full h-full object-cover" />
      </div>
    )}

    <!-- Title -->
    <h1 class="font-serif text-4xl sm:text-5xl font-bold text-brown-900 leading-tight mb-4">{title}</h1>

    {description && (
      <p class="text-lg text-brown-600 leading-relaxed mb-6">{description}</p>
    )}

    <!-- Meta strip -->
    <div class="flex flex-wrap items-center gap-x-5 gap-y-2 py-4 border-y border-tan-200 mb-8 text-sm text-brown-600">
      <span class="flex items-center gap-1.5">{emoji} <span class="capitalize">{label}</span></span>
      {prepTime && <span>⏱ Prep: <strong>{prepTime}</strong></span>}
      {cookTime && <span>🔥 Cook: <strong>{cookTime}</strong></span>}
      <span>📅 {date.toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' })}</span>
      {tags && tags.length > 0 && (
        <div class="flex gap-1.5 flex-wrap">
          {tags.map(t => (
            <span class="bg-tan-100 text-brown-600 px-2 py-0.5 rounded-full text-xs border border-tan-200">{t}</span>
          ))}
        </div>
      )}
      <button onclick="window.print()" class="ml-auto text-xs text-brown-400 hover:text-terracotta-600 transition-colors flex items-center gap-1">
        🖨️ Print
      </button>
    </div>

    <!-- Servings scaler -->
    <div id="scaler" class="flex items-center gap-4 bg-cream-50 border border-tan-200 rounded-xl px-5 py-3 mb-8">
      <span class="text-sm font-semibold text-brown-700 font-serif">Servings</span>
      <div class="flex items-center gap-3">
        <button
          id="scale-down"
          class="w-8 h-8 rounded-full bg-brown-800 text-cream-100 text-lg font-bold flex items-center justify-center hover:bg-terracotta-600 transition-colors"
          aria-label="Decrease servings"
        >−</button>
        <span
          id="servings-display"
          data-base={servings}
          class="font-serif text-2xl font-bold text-brown-900 w-8 text-center tabular-nums"
        >{servings}</span>
        <button
          id="scale-up"
          class="w-8 h-8 rounded-full bg-brown-800 text-cream-100 text-lg font-bold flex items-center justify-center hover:bg-terracotta-600 transition-colors"
          aria-label="Increase servings"
        >+</button>
      </div>
      <span class="text-xs text-brown-400">adjust ingredients below</span>
    </div>

    <!-- Recipe body -->
    <div class="recipe-content prose prose-stone max-w-none prose-headings:font-serif prose-h2:border-b prose-h2:border-tan-200 prose-h2:pb-2 prose-a:text-terracotta-600 prose-img:rounded-xl prose-img:shadow-md">
      <Content />
    </div>

  </article>
</BaseLayout>

<script>
  const display = document.getElementById('servings-display') as HTMLElement | null;
  const downBtn = document.getElementById('scale-down') as HTMLButtonElement | null;
  const upBtn   = document.getElementById('scale-up')   as HTMLButtonElement | null;

  if (!display || !downBtn || !upBtn) throw new Error('Scaler elements missing');

  const base = parseInt(display.dataset.base ?? '4', 10);
  let current = base;

  // Find ingredient list items — the <ul> immediately after <h2>Ingredients</h2>
  function getIngredientItems(): ChildNode[][] {
    const headings = document.querySelectorAll<HTMLElement>('.recipe-content h2');
    let ingredientUl: HTMLUListElement | null = null;
    headings.forEach(h => {
      if (h.textContent?.toLowerCase().includes('ingredient')) {
        const next = h.nextElementSibling;
        if (next?.tagName === 'UL') ingredientUl = next as HTMLUListElement;
      }
    });
    if (!ingredientUl) return [];

    return Array.from((ingredientUl as HTMLUListElement).querySelectorAll<HTMLLIElement>('li')).map(li => {
      // Collect only text nodes (not the checkbox input)
      return Array.from(li.childNodes).filter(n => n.nodeType === Node.TEXT_NODE);
    });
  }

  const textNodeGroups = getIngredientItems();
  // Store original text values
  const originals: string[][] = textNodeGroups.map(nodes => nodes.map(n => n.textContent ?? ''));

  const FRACTIONS: Array<[number, string]> = [
    [0.125, '⅛'], [0.25, '¼'], [0.333, '⅓'], [0.375, '⅜'],
    [0.5, '½'],   [0.625, '⅝'], [0.667, '⅔'], [0.75, '¾'], [0.875, '⅞'],
  ];

  function formatNum(n: number): string {
    if (n <= 0) return '0';
    const whole = Math.floor(n);
    const frac  = n - whole;
    if (frac < 0.01) return String(whole);
    for (const [val, sym] of FRACTIONS) {
      if (Math.abs(frac - val) < 0.04) return whole > 0 ? `${whole}${sym}` : sym;
    }
    return n % 1 === 0 ? String(n) : n.toFixed(1);
  }

  function scaleText(text: string, multiplier: number): string {
    // Match integers, decimals, and simple fractions not preceded by letters or =/"
    return text.replace(/(?<![=\w/"])(\d+(?:\.\d+)?(?:\/\d+)?)/g, match => {
      let val: number;
      if (match.includes('/')) {
        const [n, d] = match.split('/');
        val = parseFloat(n) / parseFloat(d);
      } else {
        val = parseFloat(match);
      }
      return formatNum(val * multiplier);
    });
  }

  function update(newServings: number) {
    if (newServings < 1) return;
    current = newServings;
    display.textContent = String(current);
    const multiplier = current / base;
    textNodeGroups.forEach((nodes, i) => {
      nodes.forEach((node, j) => {
        node.textContent = scaleText(originals[i][j], multiplier);
      });
    });
  }

  downBtn.addEventListener('click', () => update(current - 1));
  upBtn.addEventListener('click',   () => update(current + 1));
</script>
