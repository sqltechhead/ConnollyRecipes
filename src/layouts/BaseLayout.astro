---
import '../styles/global.css';
import { ViewTransitions } from 'astro:transitions';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'A recipe collection for smoking, baking, and cooking.' } = Astro.props;
const rawBase = import.meta.env.BASE_URL;
const base = rawBase.endsWith('/') ? rawBase : rawBase + '/';

const nav = [
  { label: 'Smoking',    href: `${base}smoking`,    emoji: '🔥' },
  { label: 'Cakes',      href: `${base}cakes`,      emoji: '🎂' },
  { label: 'Tray Bakes', href: `${base}traybakes`,  emoji: '🍫' },
  { label: 'Breads',     href: `${base}breads`,     emoji: '🍞' },
  { label: 'Cooking',    href: `${base}cooking`,    emoji: '🍳' },
  { label: 'Rubs',       href: `${base}rubs`,       emoji: '🧂' },
  { label: 'Sauces',     href: `${base}sauces`,     emoji: '🫙' },
];

const currentPath = Astro.url.pathname;
---

<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />
  <title>{title === 'Home' ? 'Connolly Recipes' : `${title} | Connolly Recipes`}</title>
  <ViewTransitions />
  <!-- Anti-flicker: apply dark class before paint -->
  <script is:inline>
    if (localStorage.getItem('theme') === 'dark') {
      document.documentElement.classList.add('dark');
    }
  </script>
</head>
<body class="min-h-screen flex flex-col bg-cream-100 dark:bg-brown-950 dark:text-cream-100">

  <!-- Scroll progress bar -->
  <div
    id="progress-bar"
    transition:persist
    class="fixed top-0 left-0 h-[3px] bg-terracotta-500 z-[200] pointer-events-none rounded-r-full"
    style="width: 0%"
  ></div>

  <header id="site-header" transition:persist class="bg-brown-900 dark:bg-brown-950 shadow-lg">
    <div class="max-w-6xl mx-auto px-4 sm:px-6">
      <div class="header-inner flex items-center justify-between h-16">
        <a href={base} class="font-serif text-xl sm:text-2xl font-bold text-cream-100 hover:text-terracotta-300 transition-colors tracking-wide">
          Connolly Recipes
        </a>
        <nav class="hidden sm:flex items-center gap-5">
          {nav.map(({ label, href }) => (
            <a
              href={href}
              class:list={['text-cream-200 hover:text-terracotta-300 transition-colors uppercase tracking-widest text-xs font-semibold', currentPath.includes(`/${label.toLowerCase()}`) && '!text-terracotta-300']}
            >
              {label}
            </a>
          ))}
        </nav>
        <div class="flex items-center gap-2">
          <!-- Shopping list -->
          <a href={`${base}shopping-list`} aria-label="Shopping list" class="relative p-2 text-cream-200 hover:text-terracotta-300 hover:bg-brown-800 rounded-lg transition-all">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z"/>
            </svg>
            <span id="cart-badge" class="absolute -top-0.5 -right-0.5 bg-terracotta-500 text-white text-[9px] font-bold min-w-[1rem] h-4 rounded-full flex items-center justify-center px-0.5 leading-none" style="display:none"></span>
          </a>
          <!-- Dark mode toggle -->
          <button
            id="theme-toggle"
            aria-label="Toggle dark mode"
            class="p-2 rounded-lg text-cream-200 hover:text-terracotta-300 hover:bg-brown-800 transition-all"
          >
            <svg id="icon-moon" xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M21 12.79A9 9 0 1111.21 3a7 7 0 109.79 9.79z"/>
            </svg>
            <svg id="icon-sun" xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364-6.364l-.707.707M6.343 17.657l-.707.707M17.657 17.657l-.707-.707M6.343 6.343l-.707-.707M12 7a5 5 0 100 10A5 5 0 0012 7z"/>
            </svg>
          </button>
          <!-- Mobile nav -->
          <details class="sm:hidden group relative">
            <summary class="list-none cursor-pointer text-cream-100 p-2">
              <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
              </svg>
            </summary>
            <div class="absolute right-0 mt-2 w-44 bg-brown-800 dark:bg-brown-950 rounded-lg shadow-xl z-50 overflow-hidden">
              {nav.map(({ label, href, emoji }) => (
                <a href={href} class="flex items-center gap-2 px-4 py-3 text-cream-200 hover:bg-brown-700 hover:text-terracotta-300 text-sm font-medium transition-colors">
                  <span>{emoji}</span>
                  <span>{label}</span>
                </a>
              ))}
              <a href={`${base}shopping-list`} class="flex items-center gap-2 px-4 py-3 text-cream-200 hover:bg-brown-700 hover:text-terracotta-300 text-sm font-medium transition-colors border-t border-brown-700">
                <span>🛒</span><span>Shopping List</span>
              </a>
            </div>
          </details>
        </div>
      </div>
    </div>
  </header>

  <main class="flex-1 max-w-6xl mx-auto w-full px-4 sm:px-6 py-8 sm:py-12">
    <slot />
  </main>

  <footer class="bg-brown-900 dark:bg-brown-950 text-cream-300 py-8 mt-8 border-t border-brown-800">
    <div class="max-w-6xl mx-auto px-6 text-center">
      <p class="font-serif text-lg mb-1">Connolly Recipes</p>
      <p class="text-sm text-cream-300 opacity-60">&copy; {new Date().getFullYear()} — smoking, baking & cooking</p>
    </div>
  </footer>

</body>
</html>

<script>
  let scrollHandlers: Array<() => void> = [];
  let ioObserver: IntersectionObserver | null = null;

  function setFavourited(btn: HTMLElement, fav: boolean) {
    btn.querySelector('.fav-heart-empty')?.classList.toggle('hidden', fav);
    btn.querySelector('.fav-heart-filled')?.classList.toggle('hidden', !fav);
  }

  function initPage() {
    // Clean up previous scroll listeners
    scrollHandlers.forEach(h => window.removeEventListener('scroll', h));
    scrollHandlers = [];

    // Clean up previous IntersectionObserver
    ioObserver?.disconnect();

    // ── Dark mode toggle ────────────────────────────────────────────────────
    const toggle = document.getElementById('theme-toggle');
    const moon   = document.getElementById('icon-moon');
    const sun    = document.getElementById('icon-sun');
    const html   = document.documentElement;

    function applyTheme(dark: boolean) {
      html.classList.toggle('dark', dark);
      moon?.classList.toggle('hidden', dark);
      sun?.classList.toggle('hidden', !dark);
    }
    applyTheme(localStorage.getItem('theme') === 'dark');

    toggle?.addEventListener('click', () => {
      const isDark = html.classList.contains('dark');
      localStorage.setItem('theme', isDark ? 'light' : 'dark');
      applyTheme(!isDark);
    });

    // ── Sticky shrinking header ─────────────────────────────────────────────
    const header = document.getElementById('site-header');
    const headerH = () => header?.classList.toggle('scrolled', window.scrollY > 30);
    window.addEventListener('scroll', headerH, { passive: true });
    scrollHandlers.push(headerH);

    // ── Scroll progress bar ─────────────────────────────────────────────────
    const bar = document.getElementById('progress-bar');
    if (bar) bar.style.width = '0%';
    const progressH = () => {
      if (!bar) return;
      const total = document.documentElement.scrollHeight - window.innerHeight;
      bar.style.width = total > 0 ? `${(window.scrollY / total) * 100}%` : '0%';
    };
    window.addEventListener('scroll', progressH, { passive: true });
    scrollHandlers.push(progressH);

    // ── Fade-up IntersectionObserver ────────────────────────────────────────
    ioObserver = new IntersectionObserver(
      entries => entries.forEach(e => {
        if (e.isIntersecting) {
          e.target.classList.add('visible');
          ioObserver?.unobserve(e.target);
        }
      }),
      { threshold: 0.1, rootMargin: '0px 0px -40px 0px' }
    );
    document.querySelectorAll('.fade-up').forEach(el => ioObserver!.observe(el));

    // ── Favourites hearts ───────────────────────────────────────────────────
    const favs = JSON.parse(localStorage.getItem('fav-recipes') ?? '[]') as string[];

    document.querySelectorAll<HTMLElement>('.fav-btn').forEach(btn => {
      const slug = btn.dataset.slug ?? '';
      setFavourited(btn, favs.includes(slug));

      btn.addEventListener('click', e => {
        e.preventDefault();
        e.stopPropagation();
        const current = JSON.parse(localStorage.getItem('fav-recipes') ?? '[]') as string[];
        const isFav = current.includes(slug);
        const updated = isFav ? current.filter(s => s !== slug) : [...current, slug];
        localStorage.setItem('fav-recipes', JSON.stringify(updated));
        document.querySelectorAll<HTMLElement>(`.fav-btn[data-slug="${slug}"]`).forEach(b => {
          setFavourited(b, !isFav);
        });
      });
    });

    // ── Card star ratings ───────────────────────────────────────────────────
    const ratings = JSON.parse(localStorage.getItem('ratings') ?? '{}') as Record<string, number>;
    document.querySelectorAll<HTMLElement>('.card-rating').forEach(el => {
      const slug = el.dataset.slug ?? '';
      const r = ratings[slug];
      if (r && r > 0) {
        el.textContent = '★'.repeat(r) + '☆'.repeat(5 - r);
        el.style.display = '';
      }
    });

    // ── Cart badge count ────────────────────────────────────────────────────
    const badge = document.getElementById('cart-badge') as HTMLElement | null;
    if (badge) {
      try {
        const list = JSON.parse(localStorage.getItem('shopping-list') ?? '[]') as Array<{ checked: boolean }>;
        const count = list.filter(i => !i.checked).length;
        badge.textContent = count > 0 ? String(count) : '';
        badge.style.display = count > 0 ? '' : 'none';
      } catch { badge.style.display = 'none'; }
    }
  }

  document.addEventListener('astro:page-load', initPage);
</script>
