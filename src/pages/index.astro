---
import BaseLayout from '../layouts/BaseLayout.astro';
import RecipeCard from '../components/RecipeCard.astro';
import { getCollection } from 'astro:content';

const all = await getCollection('recipes');
const sorted = all.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
const latest = sorted.slice(0, 6);

const rawBase = import.meta.env.BASE_URL;
const base = rawBase.endsWith('/') ? rawBase : rawBase + '/';

const categories = [
  { name: 'Smoking',    slug: 'smoking',   emoji: '🔥', desc: 'Low and slow smoked meats' },
  { name: 'Cakes',      slug: 'cakes',     emoji: '🎂', desc: 'Cakes, tarts and sweet treats' },
  { name: 'Tray Bakes', slug: 'traybakes', emoji: '🍫', desc: 'Brownies, slices and tray bakes' },
  { name: 'Breads',     slug: 'breads',    emoji: '🍞', desc: 'Breads, buns and doughs' },
  { name: 'Cooking',    slug: 'cooking',   emoji: '🍳', desc: 'Everyday cooking' },
  { name: 'Rubs',       slug: 'rubs',      emoji: '🧂', desc: 'Dry rubs and seasonings' },
  { name: 'Sauces',     slug: 'sauces',    emoji: '🫙', desc: 'BBQ sauces and condiments' },
];
---

<BaseLayout title="Home">

  <!-- Hero -->
  <div class="text-center py-10 sm:py-16 mb-10 sm:mb-14">
    <h1 class="font-serif text-5xl sm:text-6xl font-bold text-brown-900 mb-4 leading-tight">
      Connolly Recipes
    </h1>
    <p class="text-brown-600 text-lg max-w-lg mx-auto leading-relaxed">
      Straight to the point recipes — no life stories, no filler.<br class="hidden sm:block"/>
      Just smoking, baking and cooking.
    </p>
    <div class="mt-6 w-16 h-0.5 bg-terracotta-500 mx-auto rounded-full"></div>
  </div>

  <!-- Category grid -->
  <section class="mb-14">
    <h2 class="font-serif text-2xl text-brown-800 mb-5">Browse by category</h2>
    <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-5 gap-3">
      {categories.map(({ name, slug, emoji, desc }) => (
        <a
          href={`${base}${slug}`}
          class="flex flex-col items-center justify-center gap-2 p-5 rounded-xl border-2 border-tan-200 bg-cream-50 hover:border-terracotta-400 hover:bg-terracotta-100 transition-all duration-200 group text-center"
        >
          <span class="text-3xl">{emoji}</span>
          <span class="font-serif font-semibold text-brown-900 group-hover:text-terracotta-700 transition-colors">{name}</span>
          <span class="text-xs text-brown-500 leading-tight hidden sm:block">{desc}</span>
        </a>
      ))}
    </div>
  </section>

  <!-- Latest recipes -->
  <section>
    <div class="flex items-baseline justify-between mb-5">
      <h2 class="font-serif text-2xl text-brown-800">Latest recipes</h2>
      <span class="text-sm text-brown-500">{all.length} recipes total</span>
    </div>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
      {latest.map(r => (
        <RecipeCard
          title={r.data.title}
          slug={r.slug}
          category={r.data.category}
          date={r.data.date}
          image={r.data.image}
          cookTime={r.data.cookTime}
          description={r.data.description}
          tags={r.data.tags}
        />
      ))}
    </div>
  </section>

</BaseLayout>
